rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'iamshanto7860@gmail.com';
    }

    function isTenantOwner(tenantId) {
      let tenantDoc = get(/databases/$(database)/documents/tenants/$(tenantId));
      return tenantDoc != null && tenantDoc.data.ownerEmail == request.auth.token.email;
    }

    function isTenantAdmin(tenantId) {
      return isSuperAdmin() || isTenantOwner(tenantId);
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSettings(data) {
      let isBasicValid = data.keys().hasAll(['restaurantName', 'heroTitle', 'heroSubtitle', 'contactEmail', 'address', 'isOpen', 'whatsappNumber', 'mbWayNumber', 'deliveryFee'])
        && data.restaurantName is string && data.restaurantName.size() <= 200
        && data.heroTitle is string && data.heroTitle.size() <= 200
        && data.heroSubtitle is string && data.heroSubtitle.size() <= 200
        && data.contactEmail is string && data.contactEmail.size() <= 200
        && data.address is string && data.address.size() <= 500
        && data.isOpen is bool
        && data.whatsappNumber is string && data.whatsappNumber.size() <= 50
        && data.mbWayNumber is string && data.mbWayNumber.size() <= 50
        && data.deliveryFee is number;
      
      let deliveryZonesValid = (!('deliveryZones' in data) || (data.deliveryZones is list && data.deliveryZones.size() <= 50));
      return isBasicValid && deliveryZonesValid;
    }

    match /tenants/{tenantId} {
      allow get: if true;
      allow list: if true; 
      allow write: if isSuperAdmin(); // Allow admins to manage tenants.
    }

    function isValidMenu(data) {
      let isBasicValid = data.keys().hasAll(['name', 'price', 'description', 'category', 'imageURL', 'isAvailable', 'createdAt'])
        && data.name is string && data.name.size() <= 200
        && data.price is number
        && data.description is string && data.description.size() <= 1000
        && data.category is string && data.category.matches('^(Cheesesteaks|Burgers|Sides|Drinks)$')
        && data.imageURL is string && data.imageURL.size() <= 500000
        && data.isAvailable is bool
        && data.createdAt is number;
      
      let optionsValid = (!('options' in data) || (data.options is list && data.options.size() <= 20));
      return isBasicValid && optionsValid;
    }

    function isValidOrder(data) {
      let isBasicValid = data.keys().hasAll(['customerName', 'customerPhone', 'orderType', 'items', 'totalPrice', 'deliveryFee', 'status', 'createdAt'])
        && data.customerName is string && data.customerName.size() <= 200
        && data.customerPhone is string && data.customerPhone.size() <= 50
        && data.orderType is string && data.orderType.matches('^(Eat-in|Takeaway|Delivery)$')
        && data.items is list && data.items.size() <= 50
        && data.totalPrice is number
        && data.deliveryFee is number
        && data.status is string && data.status.matches('^(Pending|Preparing|Ready|Delivered|Cancelled)$')
        && data.createdAt is number;
      
      let addressValid = !('customerAddress' in data) || (data.customerAddress is string && data.customerAddress.size() <= 500);
      let zipCodeValid = !('customerZipCode' in data) || (data.customerZipCode is string && data.customerZipCode.size() <= 50);
      
      return isBasicValid && addressValid && zipCodeValid;
    }

    match /restaurants/{tenantId} {
      match /settings/{settingsId} {
        allow get: if true;
        allow list: if true; 
        allow create: if isTenantAdmin(tenantId) && isValidId(settingsId) && isValidSettings(incoming());
        allow update: if isTenantAdmin(tenantId) && isValidId(settingsId) && isValidSettings(incoming());
        allow delete: if false; 
      }

      match /menu/{menuId} {
        allow get: if isValidId(menuId);
        allow list: if true; 
        allow create: if isTenantAdmin(tenantId) && isValidId(menuId) && isValidMenu(incoming());
        allow update: if isTenantAdmin(tenantId) && isValidId(menuId) && isValidMenu(incoming());
        allow delete: if isTenantAdmin(tenantId) && isValidId(menuId);
      }

      match /orders/{orderId} {
        allow get: if isTenantAdmin(tenantId) && isValidId(orderId);
        allow list: if isTenantAdmin(tenantId);
        allow create: if isValidOrder(incoming()); // removed isValidId(orderId) to let firebase generate via setDoc or addDoc
        allow update: if isTenantAdmin(tenantId) && isValidId(orderId) && isValidOrder(incoming());
        allow delete: if isTenantAdmin(tenantId) && isValidId(orderId);
      }
    }
  }
}
